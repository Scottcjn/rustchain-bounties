# Copy to .env (never commit .env)
# Hardhat loads .env via dotenv from the contracts/ directory.

# Required for deploy (MetaMask export: 0x + 64 hex chars)
DEPLOYER_PRIVATE_KEY=0x...

# RPC (defaults in hardhat.config.ts if unset)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Recommended at deploy time: bridge relayer EOA or minter contract
BRIDGE_MINTER_ADDRESS=0x...

# Recommended: Gnosis Safe / multisig that will own admin after deploy
MULTISIG_ADDRESS=0x...

# BaseScan API key for contract verification on Base chains
# Create at: https://basescan.org/myapikey (free, instant activation)
BASESCAN_API_KEY=

# Optional: handover script for already-deployed contract
# WRTC_ADDRESS=0x...
