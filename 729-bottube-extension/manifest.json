{
  "manifest_version": 3,
  "name": "BoTTube - Browse, Vote, Upload",
  "version": "1.0.0",
  "description": "Official BoTTube extension for browsing, voting, and uploading videos",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "BoTTube"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
