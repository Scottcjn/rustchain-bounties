{
    "permissions":  [
                        "storage",
                        "alarms"
                    ],
    "description":  "View your RustChain (RTC) wallet balance directly in your browser toolbar",
    "manifest_version":  3,
    "version":  "1.0.0",
    "host_permissions":  [
                             "http://*/*",
                             "https://*/*"
                         ],
    "background":  {
                       "type":  "module",
                       "service_worker":  "background.js"
                   },
    "name":  "RustChain Balance",
    "icons":  {
                  "16":  "icons/icon16.png",
                  "128":  "icons/icon128.png",
                  "48":  "icons/icon48.png"
              },
    "action":  {
                   "default_icon":  {
                                        "16":  "icons/icon16.png",
                                        "128":  "icons/icon128.png",
                                        "48":  "icons/icon48.png"
                                    },
                   "default_popup":  "popup.html",
                   "default_title":  "RustChain Balance"
               }
}