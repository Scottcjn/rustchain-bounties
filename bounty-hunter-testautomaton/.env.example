# Required for AI-powered evaluation + code generation
ANTHROPIC_API_KEY=sk-ant-...

# Your RustChain wallet name (shown in PR claim)
WALLET_NAME=your_wallet_name

# Optional — gh CLI uses its own auth by default
# GITHUB_TOKEN=ghp_...

# Minimum score (0-10) to auto-claim a bounty
MIN_SCORE=5.0

# Set to "false" to allow competing PRs
SKIP_IF_PR_OPEN=true
