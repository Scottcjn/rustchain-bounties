			]
		},
		{
			"name": "Attestation Flow (RIP-200)",
			"description": "The RIP-200 Proof-of-Attestation flow: request a challenge nonce, submit hardware fingerprint proof, then enroll in the current epoch for reward distribution.\n\nThese endpoints must be called in order:\n1. POST /attest/challenge → get a nonce\n2. POST /attest/submit → submit proof with the nonce\n3. POST /epoch/enroll → enroll for rewards",
			"item": [
				{
					"name": "Step 1 – Request Attestation Challenge",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/attest/challenge",
							"host": ["{{baseUrl}}"],
							"path": ["attest", "challenge"]
						},
						"description": "Request a fresh nonce from the node.\n\nNonces are short-lived (typically 10 minutes) to prevent replay attacks. The returned nonce must be included in the attestation submission (Step 2)."
					},
					"response": [
						{
							"name": "Challenge Nonce",
							"originalRequest": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{}",
									"options": {
										"raw": {
											"language": "json"
										}
									}
								},
								"url": {
									"raw": "{{baseUrl}}/attest/challenge",
									"host": ["{{baseUrl}}"],
									"path": ["attest", "challenge"]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"nonce\": \"a1b2c3d4e5f6...\",\n  \"server_time\": 1771038696,\n  \"expires_at\": 1771038996\n}"
						}
					]
				},
				{
					"name": "Step 2 – Submit Attestation Proof",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"miner\": \"WALLET_ADDRESS_RTC\",\n  \"miner_id\": \"FRIENDLY_DEVICE_NAME\",\n  \"nonce\": \"SERVER_PROVIDED_NONCE\",\n  \"report\": {\n    \"commitment\": \"sha256(nonce + wallet + entropy_data)\",\n    \"entropy_score\": 0.0045,\n    \"derived\": {\n      \"mean_ns\": 25000,\n      \"variance_ns\": 450\n    }\n  },\n  \"device\": {\n    \"family\": \"PowerPC\",\n    \"arch\": \"g4\",\n    \"model\": \"PowerMac3,6\",\n    \"serial\": \"CK245...\"\n  },\n  \"fingerprint\": {\n    \"all_passed\": true,\n    \"checks\": {\n      \"clock_skew\": true,\n      \"cache_timing\": true,\n      \"simd_identity\": true,\n      \"thermal_drift\": true,\n      \"instruction_jitter\": true,\n      \"vm_detection\": true\n    }\n  }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/attest/submit",
							"host": ["{{baseUrl}}"],
							"path": ["attest", "submit"]
						},
						"description": "Submit a hardware fingerprint and entropy report for attestation.\n\nThe payload must include the nonce from Step 1, the miner's wallet address, a cryptographic commitment (sha256 of nonce + wallet + entropy data), device information, and the results of all 6+1 hardware fingerprint checks.\n\nSee docs/protocol/ATTESTATION.md for the full payload specification and check descriptions."
					},
					"response": [
						{
							"name": "Attestation Accepted",
							"originalRequest": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"miner\": \"WALLET_ADDRESS_RTC\",\n  \"miner_id\": \"FRIENDLY_DEVICE_NAME\",\n  \"nonce\": \"SERVER_PROVIDED_NONCE\",\n  \"report\": {\n    \"commitment\": \"sha256(nonce + wallet + entropy_data)\",\n    \"entropy_score\": 0.0045,\n    \"derived\": { \"mean_ns\": 25000, \"variance_ns\": 450 }\n  },\n  \"device\": {\n    \"family\": \"PowerPC\",\n    \"arch\": \"g4\",\n    \"model\": \"PowerMac3,6\",\n    \"serial\": \"CK245...\"\n  },\n  \"fingerprint\": {\n    \"all_passed\": true,\n    \"checks\": {}\n  }\n}",
									"options": {
										"raw": {
											"language": "json"
										}
									}
								},
								"url": {
									"raw": "{{baseUrl}}/attest/submit",
									"host": ["{{baseUrl}}"],
									"path": ["attest", "submit"]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"status\": \"accepted\",\n  \"miner_id\": \"FRIENDLY_DEVICE_NAME\",\n  \"ttl_s\": 600\n}"
						}
					]
				},
				{
					"name": "Step 3 – Enroll in Epoch",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"miner_pubkey\": \"RTC_WALLET_ADDRESS\",\n  \"miner_id\": \"FRIENDLY_ID\",\n  \"device\": {\n    \"family\": \"PowerPC\",\n    \"arch\": \"g4\"\n  }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/epoch/enroll",
							"host": ["{{baseUrl}}"],
							"path": ["epoch", "enroll"]
						},
						"description": "Enroll a miner in the current epoch for reward distribution.\n\nRequires a recent successful attestation (Step 2). If called without one, the node returns an error with `error: \"no_recent_attestation\"` and a TTL in seconds.\n\nThe device family and arch must match the values used during attestation."
					},
					"response": [
						{
							"name": "Enrollment Accepted",
							"originalRequest": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"miner_pubkey\": \"RTC_WALLET_ADDRESS\",\n  \"miner_id\": \"FRIENDLY_ID\",\n  \"device\": {\n    \"family\": \"PowerPC\",\n    \"arch\": \"g4\"\n  }\n}",
									"options": {
										"raw": {
											"language": "json"
										}
									}
								},
								"url": {
									"raw": "{{baseUrl}}/epoch/enroll",
									"host": ["{{baseUrl}}"],
									"path": ["epoch", "enroll"]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"status\": \"enrolled\",\n  \"epoch\": 73,\n  \"miner_id\": \"FRIENDLY_ID\"\n}"
						},
						{
							"name": "No Recent Attestation",
							"originalRequest": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n  \"miner_pubkey\": \"RTC_WALLET_ADDRESS\",\n  \"miner_id\": \"FRIENDLY_ID\",\n  \"device\": {\n    \"family\": \"PowerPC\",\n    \"arch\": \"g4\"\n  }\n}",
									"options": {
										"raw": {
											"language": "json"
										}
									}
								},
								"url": {
									"raw": "{{baseUrl}}/epoch/enroll",
									"host": ["{{baseUrl}}"],
									"path": ["epoch", "enroll"]
								}
							},
							"status": "Forbidden",
							"code": 403,
							"_postman_previewlanguage": "json",
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"error\": \"no_recent_attestation\",\n  \"ttl_s\": 600\n}"
						}
					]
				}
			]
		},
