									"raw": "{{baseUrl}}/wallet/balance?miner_id={{minerId}}",
									"host": ["{{baseUrl}}"],
									"path": ["wallet", "balance"],
									"query": [
										{
											"key": "miner_id",
											"value": "{{minerId}}"
										}
