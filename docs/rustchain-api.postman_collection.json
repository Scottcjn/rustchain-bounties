								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"amount_i64\": 265420827,\n  \"amount_rtc\": 265.420827,\n  \"miner_id\": \"victus-x86-scott\"\n}"
						}
