		{
			"name": "Wallet",
			"description": "Endpoints for querying RTC wallet balances.",
			"item": [
				{
					"name": "Get Wallet Balance",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/wallet/balance?miner_id={{minerId}}",
							"host": ["{{baseUrl}}"],
							"path": ["wallet", "balance"],
							"query": [
								{
									"key": "miner_id",
									"value": "{{minerId}}",
									"description": "(Required) The miner / wallet ID to query"
								}
							]
						},
						"description": "Returns the current RTC balance for a specific miner/wallet ID.\n\nThe response includes both the raw integer amount (`amount_i64`) and the human-readable RTC value (`amount_rtc`)."
					},
					"response": [
						{
							"name": "Balance Response",
							"originalRequest": {
								"method": "GET",
								"header": [],
