									"path": ["api", "miners"]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "[\n  {\n    \"miner\": \"victus-x86-scott\",\n    \"hardware_type\": \"x86_64\",\n    \"device_arch\": \"x86_64\",\n    \"device_family\": \"Modern x86\",\n    \"antiquity_multiplier\": 1.0,\n    \"last_attest\": 1771038696,\n    \"entropy_score\": 0.0045\n  },\n  {\n    \"miner\": \"g4-cube-retro\",\n    \"hardware_type\": \"PowerPC\",\n    \"device_arch\": \"g4\",\n    \"device_family\": \"PowerPC\",\n    \"antiquity_multiplier\": 2.5,\n    \"last_attest\": 1771038400,\n    \"entropy_score\": 0.0032\n  }\n]"
						}
					]
				}
