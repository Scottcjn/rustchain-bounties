{
	"info": {
		"name": "RustChain API",
		"description": "Complete Postman collection for the RustChain node API.\n\nBase URL: https://50.28.86.131\n\n**TLS note:** The node uses a self-signed certificate. Disable certificate verification in Postman settings (Settings → General → SSL certificate verification → OFF) or in the request settings.\n\n**Rate limiting:** If you receive HTTP 429, back off and retry with exponential delay (2 s, 4 s, 8 s …).\n\nSee the full API specification at docs/protocol/API_SPEC.md.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "https://50.28.86.131",
			"type": "string",
			"description": "RustChain node base URL"
		},
		{
			"key": "minerId",
			"value": "victus-x86-scott",
			"type": "string",
			"description": "Miner / wallet ID used for balance and eligibility queries"
		}
	],
	"item": [
		{
			"name": "Network Health & Status",
			"description": "Endpoints for checking node health and current epoch information.",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						},
						"description": "Returns the status of the node, database, and blockchain tip.\n\nA healthy node returns `ok: true` along with uptime, backup freshness, and the current software version."
					},
					"response": [
						{
							"name": "Healthy Node",
							"originalRequest": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{baseUrl}}/health",
									"host": ["{{baseUrl}}"],
									"path": ["health"]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"backup_age_hours\": 0.08,\n  \"db_rw\": true,\n  \"ok\": true,\n  \"tip_age_slots\": 0,\n  \"uptime_s\": 24000,\n  \"version\": \"2.2.1-rip200\"\n}"
						}
					]
				},
				{
					"name": "Current Epoch",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/epoch",
							"host": ["{{baseUrl}}"],
							"path": ["epoch"]
						},
						"description": "Returns the current slot number, epoch progress, enrolled miner count, and the reward pot for the active epoch.\n\nEpochs are approximately 10 minutes long (144 blocks per day)."
					},
					"response": [
						{
							"name": "Epoch Info",
							"originalRequest": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{baseUrl}}/epoch",
									"host": ["{{baseUrl}}"],
									"path": ["epoch"]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"body": "{\n  \"blocks_per_epoch\": 144,\n  \"enrolled_miners\": 12,\n  \"epoch\": 73,\n  \"epoch_pot\": 1.5,\n  \"slot\": 10554\n}"
						}
					]
				}
			]
		},
		{
			"name": "Miners",
			"description": "Endpoints for listing active miners on the network.",
			"item": [
				{
					"name": "List Active Miners",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/miners",
							"host": ["{{baseUrl}}"],
							"path": ["api", "miners"]
						},
						"description": "Returns a JSON array of all currently attested and active miners.\n\nEach entry includes the miner wallet address, hardware type, device architecture, device family, antiquity multiplier, last attestation timestamp, and entropy score."
					},
					"response": [
						{
							"name": "Active Miners List",
							"originalRequest": {
								"method": "GET",
								"header": [],
