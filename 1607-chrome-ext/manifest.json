{
  "manifest_version": 3,
  "name": "RustChain Balance Checker",
  "version": "1.0.0",
  "description": "Check RTC balance directly from your browser",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
