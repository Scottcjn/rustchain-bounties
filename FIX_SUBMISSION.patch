</html>

// settings.html
<!DOCTYPE html>
<html>
  <head>
    <title>BoTTube Settings</title>
    <style>
      body {
        width: 200px;
        height: 100px;
        font-family: Arial, sans-serif;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <h1>BoTTube Settings</h1>
    <input id="api-key-input" type="text" placeholder="API Key">
    <button id="save-api-key-button">Save</button>
    <script src="settings.js"></script>
  </body>
</html>

// settings.js
document.addEventListener("DOMContentLoaded", function () {
  const apiKeyInput = document.getElementById("api-key-input");
  const saveApiKeyButton = document.getElementById("save-api-key-button");

  saveApiKeyButton.addEventListener("click", function () {
    const apiKey = apiKeyInput.value;
    chrome.runtime.sendMessage({ action: "setApiKey", apiKey: apiKey });
  });
});
