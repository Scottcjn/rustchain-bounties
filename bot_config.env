# Telegram Bot Configuration
# Copy this file to bot.env and fill in your values

# Telegram Bot Token (get from @BotFather)
RUSTCHAIN_BOT_TOKEN=your_bot_token_here

# RustChain API URL (if applicable)
RUSTCHAIN_API_URL=https://api.rustchain.com

# Database configuration (if applicable)
DATABASE_URL=sqlite:///rustchain_bots.db
