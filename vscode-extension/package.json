{
  "name": "rustchain-dashboard",
  "displayName": "RustChain Dashboard",
  "version": "1.0.0",
  "description": "VS Code extension for RustChain wallet balance, miner status, and bounty browser",
  "publisher": "shuziyoumin2",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "Developer Tools"
  ],
  "keywords": [
    "rustchain",
    "cryptocurrency",
    "dashboard",
    "wallet",
    "miner",
    "bounty"
  ],
  "activationEvents": [
    "onView:rustchain-bounties",
    "onCommand:rustchain.refresh",
    "onCommand:rustchain.openBounty"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rustchain-sidebar",
          "title": "RustChain",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": [
      {
        "id": "rustchain-bounties",
        "type": "webview",
        "containerId": "rustchain-sidebar",
        "name": "RustChain Dashboard"
      }
    ],
    "viewsWelcome": [
      {
        "view": "rustchain-bounties",
        "contents": "## RustChain Dashboard\n\nConfigure your wallet in Settings to get started.\n\n**Settings:**\n- `rustchain.walletName`: Your RustChain wallet name\n- `rustchain.nodeUrl`: RustChain node URL (default: https://50.28.86.131)"
      }
    ],
    "commands": [
      {
        "command": "rustchain.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "rustchain.openBounty",
        "title": "Open Bounty"
      },
      {
        "command": "rustchain.claimBounty",
        "title": "Claim Bounty"
      }
    ],
    "configuration": [
      {
        "title": "RustChain",
        "properties": {
          "rustchain.walletName": {
            "type": "string",
            "default": "",
            "description": "Your RustChain wallet name"
          },
          "rustchain.nodeUrl": {
            "type": "string",
            "default": "https://50.28.86.131",
            "description": "RustChain node URL"
          },
          "rustchain.refreshInterval": {
            "type": "number",
            "default": 60,
            "description": "Auto-refresh interval in seconds"
          }
        }
      }
    ],
    "statusBar": [
      {
        "id": "rustchain-balance",
        "text": "$(rustchain-icon) Loading...",
        "tooltip": "RustChain Balance",
        "command": "rustchain.refresh"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^16.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.3.0",
    "typescript": "^5.0.0"
  }
}
