+
+class StressTestUser(HttpUser):
+    """
+    Aggressive stress testing user - simulates high load scenarios.
+    Shorter wait times, more frequent requests.
+    """
+    
+    wait_time = between(0.1, 0.5)
+    
+    @task
+    def rapid_health_checks(self):
