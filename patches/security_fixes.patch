+# Rate limiting storage (in production, use Redis or database)
+user_request_counts = {}
+RATE_LIMIT_REQUESTS = 10
+RATE_LIMIT_WINDOW = 60  # seconds
+
+def rate_limit(func):
+    """Rate limiting decorator"""
+    @wraps(func)
+    async def wrapper(update: Update, context: ContextTypes.DEFAULT_TYPE):
+        user_id = update.effective_user.id
+        current_time = time.time()
+        
+        # Clean old entries
+        if user_id in user_request_counts:
+            user_request_counts[user_id] = [
+                timestamp for timestamp in user_request_counts[user_id] 
+                if current_time - timestamp < RATE_LIMIT_WINDOW
+            ]
+        else:
+            user_request_counts[user_id] = []
+        
+        # Check rate limit
+        if len(user_request_counts[user_id]) >= RATE_LIMIT_REQUESTS:
+            await update.message.reply_text(
+                "Rate limit exceeded. Please wait before sending more requests."
+            )
+            return
+        
+        # Add current request
+        user_request_counts[user_id].append(current_time)
+        
+        return await func(update, context)
+    return wrapper
+
+def validate_input(text: str, max_length: int = 1000) -> str:
+    """Validate and sanitize user input"""
+    if not isinstance(text, str):
+        raise ValueError("Input must be a string")
+    
+    # Remove potentially dangerous characters
+    text = re.sub(r'[<>"\'\(\){}[\]\\]', '', text)
+    
+    # Limit length
+    text = text[:max_length]
+    
+    # Remove excessive whitespace
+    text = ' '.join(text.split())
+    
+    return text
+
+def validate_webhook(token: str, data: dict, signature: str) -> bool:
+    """Validate webhook signature to prevent tampering"""
+    expected_signature = hmac.new(
+        token.encode('utf-8'),
+        json.dumps(data, sort_keys=True).encode('utf-8'),
+        hashlib.sha256
+    ).hexdigest()
+    
+    return hmac.compare_digest(expected_signature, signature)
+
