# Environment variables (do NOT commit secrets)

# LLM provider: "anthropic" | "openai" | "offline" (default: offline)
LLM_PROVIDER=offline
# LLM_API_URL is auto-resolved per provider; override if using a proxy
# LLM_API_URL=https://api.anthropic.com/v1/messages
LLM_API_KEY=your_api_key_here
# LLM_MODEL overrides the default model per provider
# LLM_MODEL=claude-sonnet-4-6

# Platform posting (BoTTube) — leave empty for dry-run
PLATFORM_API_BASE=https://api.bottube.example
PLATFORM_API_KEY=

# Bot settings
BOT_AUTHOR_NAME=GritBot
BOT_DEFAULT_TONE=informal
