# Environment variables (do NOT commit secrets)
# LLM
LLM_API_URL=https://api.openai.example/v1/chat/completions
LLM_API_KEY=your_llm_api_key_here

# Platform posting (BoTTube) - use staging/test creds
PLATFORM_API_BASE=https://api.bottube.example
PLATFORM_API_KEY=your_platform_api_key_here

# Bot settings
BOT_AUTHOR_NAME=GritBot
BOT_DEFAULT_TONE=informal
